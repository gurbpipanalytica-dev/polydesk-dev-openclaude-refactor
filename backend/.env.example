# Polydesk Environment Variables
# Copy to .env and fill in your values

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key

GEMINI_API_KEY=your_gemini_key
ANTHROPIC_API_KEY=sk-ant-api03-xxx
OPENAI_API_KEY=sk-xxx

POLYMARKET_PRIVATE_KEY=0x_your_wallet_private_key
POLYMARKET_API_KEY=your_pm_api_key
POLYMARKET_API_SECRET=your_pm_api_secret
POLYMARKET_PASSPHRASE=your_pm_passphrase

LIVE_MODE=false
TOTAL_CAPITAL_USD=450
STATE_DIR=/app/state
